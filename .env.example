NEXT_PUBLIC_API_URL=
BASE_URL=
ONEENTRY_URL=
ONEENTRY_TOKEN=
GOOGLE_CLIENT_ID=

# ═══════════════════════════════════════════════════════════════════════════                                                
# ISR — Incremental Static Regeneration
# ═══════════════════════════════════════════════════════════════════════════                                                
# How many seconds Next.js serves the cached HTML of a page before it                                                        
# triggers a background re-render. Within that window every visitor gets                                                     
# pre-rendered HTML in milliseconds. When the window elapses, the next                                                       
# request kicks off a refresh while other visitors keep seeing the previous                                                  
# version until the refresh completes.                    
#                                                                                                                            
# All variables are optional — when unset, defaults from src/lib/isr.ts are
# used. Values must be positive integers (seconds).                                                                          
                                                                                                                            
# Homepage. 5 min — trade-off between banner / homepage-block freshness and                                                  
# SDK call cost at peak load.                                                                                                
ISR_HOME_TTL_SEC=300                                                                                                         
                                                        
# Product Detail Page. 2 min — intentionally short because a stale price /                                                   
# stock on a PDP can cause a shopper to hit "Place Order" on an unavailable
# item. Belt-and-braces safety: a fresh previewOrder runs right before                                                       
# createOrder on checkout (src/app/pages/PaymentPage.tsx).
ISR_PRODUCT_TTL_SEC=120                                                                                                      
                                                                                                                            
# Catalog (/women/shoes and the other 7 shelves). ISR only applies to clean                                                  
# URLs. URLs with filters / sort / pagination (?color=Black&sort=price)                                                      
# still SSR on every request (dynamic auto).                                                                                 
ISR_CATALOG_TTL_SEC=60                                                                                                       
                                                                                                                            
# Sale page. Short window because of the countdown timer and time-sensitive                                                  
# banners.                                                
ISR_SALE_TTL_SEC=60                                                                                                          
                                                        
# New Arrivals. 10 min is enough — content is nearly static and rarely                                                       
# refreshed.
ISR_NEW_TTL_SEC=600                                                                                                          
                                                        
# /stores — store locator. 60 min — physical stores rarely change.                                                           
ISR_STORES_TTL_SEC=3600
                                                                                                                            
# /info/* — returns, delivery, FAQ, about, etc. Rarely updated.                                                              
ISR_INFO_TTL_SEC=3600
                                                                                                                            
# Master switch. When =1 every ISR window collapses to 1 second, which                                                       
# effectively turns pages into SSR-per-request. Useful in dev / staging
# when an admin is editing OE content and wants to see changes immediately                                                   
# without waiting for the revalidate window.              
ISR_DISABLED=1                                                                                                             
                                                        
# ═══════════════════════════════════════════════════════════════════════════                                                
# OE loader profiling                                     
# ═══════════════════════════════════════════════════════════════════════════                                                
# Logs the wall-clock time of every wrapped OneEntry SDK loader call
# (loadProducts, loadStores, loadBlockWithProducts, etc.). Helps identify                                                    
# the slowest call under load testing and pinpoint where p95 grows. Off by
# default — the wrapper is a no-op with zero overhead in production.                                                         
                                                        
# Enable profiling. When =1 every wrapped loader emits a stdout line                                                         
# `[OE-timing] <name> ok <ms>ms` (or `FAIL <ms>ms` on error). Cache hits
# usually land around 1 ms; cache misses show the real round-trip time.                                                      
# Requires a next dev restart / redeploy after toggling.  
OE_PROFILE=1                                                                                                               
                                                        
# Log threshold — only emit calls slower than N milliseconds. Default 0                                                      
# (log everything). Use this when OE_PROFILE=1 produces too much noise and
# you only want the "interesting" outliers.                                                                                  
OE_PROFILE_SLOW_MS=100                          